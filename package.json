{
  "name": "codex-workflow",
  "type": "module",
  "private": false,
  "bin": {
    "codex-workflow": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint src test tsdown.config.ts eslint.config.mjs",
    "lint:fix": "eslint src test tsdown.config.ts eslint.config.mjs --fix",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && node --test",
    "prepack": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "install:codex": "node dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "1.5.1",
    "ansis": "4.3.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@types/node": "25.9.3",
    "eslint": "10.5.0",
    "tsdown": "0.22.3",
    "typescript": "6.0.3"
  }
}
